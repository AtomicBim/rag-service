# =============================================================================
# RAG Service Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your actual values

# AI Models Configuration
MODEL_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash
TEMPERATURE=0.1

# API Keys (REQUIRED)
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Service Ports
RAG_BOT_PORT=8000
RAG_CHAT_PORT=7860

# Qdrant Vector Database
QDRANT_HOST=192.168.42.188
QDRANT_PORT=6333
COLLECTION_NAME=internal_regulations_v2
SEARCH_LIMIT=20

# Search Parameters Defaults
DEFAULT_THRESHOLD=0.7
DEFAULT_SEARCH_TYPE=hybrid
DEFAULT_RERANK=true

# External Services (GPU машина)
EMBEDDING_SERVICE_HOST=192.168.45.55
EMBEDDING_SERVICE_PORT=8001

# Search Service (GPU машина с продвинутым поиском)
SEARCH_SERVICE_HOST=192.168.45.55
SEARCH_SERVICE_PORT=8002

# Proxy Configuration
PROXY_HOST=172.17.0.1
PROXY_PORT=10808

# Internal Network Exceptions (comma-separated, no spaces)
NO_PROXY_INTERNAL=192.168.42.188,192.168.45.64
NO_PROXY_SERVICES=localhost,127.0.0.1,rag-chat

# Gradio Configuration
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_TITLE=RAG-система для ВНД Атомстройкомплекс
GRADIO_DESCRIPTION=Введите свой вопрос. Система найдет релевантные документы и сгенерирует ответ.
GRADIO_SHOW_API=false
GRADIO_SHOW_ERROR=true

# Logging
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO